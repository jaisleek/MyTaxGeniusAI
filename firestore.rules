rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation for User Entity
    function isValidUser(data, userId) {
      return 
        data.keys().hasAll(['fullName', 'email', 'createdAt']) &&
        data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 100 &&
        data.email is string && data.email.size() > 0 && data.email.size() <= 100 &&
        (data.get('phone', '') is string && data.get('phone', '').size() <= 20) &&
        (data.get('taxId', '') is string && data.get('taxId', '').size() <= 20) &&
        (data.get('profilePicture', '') is string && data.get('profilePicture', '').size() <= 2000000) &&
        (data.get('signature', '') is string && data.get('signature', '').size() <= 2000000) &&
        (data.get('address', '') is string && data.get('address', '').size() <= 200) &&
        (data.get('businessName', '') is string && data.get('businessName', '').size() <= 100) &&
        (data.get('businessType', '') is string && data.get('businessType', '').size() <= 50) &&
        (data.get('onboardingComplete', false) is bool) &&
        data.createdAt == request.time;
    }

    // Validation for ReminderSubscription Entity
    function isValidReminderSubscription(data) {
      return 
        data.keys().hasAll(['email', 'createdAt']) &&
        data.email is string && data.email.size() > 0 && data.email.size() <= 100 &&
        data.createdAt == request.time;
    }

    // Validation for DashboardAlertSubscription Entity
    function isValidDashboardAlertSubscription(data) {
      return 
        data.keys().hasAll(['userId', 'alertEmail', 'createdAt']) &&
        data.userId is string && data.userId.size() > 0 && data.userId.size() <= 128 &&
        data.userId == request.auth.uid &&
        data.alertEmail is string && data.alertEmail.size() > 0 && data.alertEmail.size() <= 100 &&
        data.createdAt == request.time;
    }

    // Users Collection
    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      // No blanket list allowed for users to protect PII
      
      allow create: if 
        isSignedIn() && 
        isOwner(userId) && 
        isValidId(userId) &&
        isValidUser(incoming(), userId);
        
      allow update: if
        isSignedIn() &&
        isOwner(userId) &&
        isValidId(userId) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'phone', 'taxId', 'profilePicture', 'signature', 'address', 'businessName', 'businessType', 'onboardingComplete']) &&
        incoming().get('fullName', existing().get('fullName', '')) is string &&
        (incoming().get('phone', '') is string && incoming().get('phone', '').size() <= 20) &&
        (incoming().get('taxId', '') is string && incoming().get('taxId', '').size() <= 20) &&
        (incoming().get('profilePicture', '') is string && incoming().get('profilePicture', '').size() <= 2000000) &&
        (incoming().get('signature', '') is string && incoming().get('signature', '').size() <= 2000000) &&
        (incoming().get('address', '') is string && incoming().get('address', '').size() <= 200) &&
        (incoming().get('businessName', '') is string && incoming().get('businessName', '').size() <= 100) &&
        (incoming().get('businessType', '') is string && incoming().get('businessType', '').size() <= 50) &&
        (incoming().get('onboardingComplete', false) is bool);
    }

    // Reminder Subscriptions Collection
    match /reminderSubscriptions/{subscriptionId} {
      allow create: if 
        isValidId(subscriptionId) &&
        isValidReminderSubscription(incoming());
    }

    // Dashboard Alert Subscriptions Collection
    match /dashboardAlertSubscriptions/{subscriptionId} {
      allow get: if isSignedIn() && isOwner(subscriptionId);
      allow create: if 
        isSignedIn() &&
        isValidId(subscriptionId) &&
        isValidDashboardAlertSubscription(incoming());
      allow update: if
        isSignedIn() &&
        isOwner(existing().userId) &&
        isValidId(subscriptionId) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['alertEmail']) &&
        incoming().alertEmail is string && incoming().alertEmail.size() > 0 && incoming().alertEmail.size() <= 100;
    }
    // Validation for Expense Entity
    function isValidExpense(data, userId) {
      return 
        data.keys().hasAll(['userId', 'date', 'amount', 'category', 'description', 'createdAt']) &&
        data.userId == userId &&
        data.date is string && data.date.size() <= 50 &&
        (data.amount is number || data.amount is string) &&
        data.category is string && data.category.size() <= 50 &&
        data.description is string && data.description.size() <= 200 &&
        (data.get('isDeductible', false) is bool) &&
        (data.get('proofUrl', '') is string && data.get('proofUrl', '').size() <= 1000) &&
        data.createdAt == request.time;
    }

    // Validation for Invoice Entity
    function isValidInvoice(data, userId) {
      return 
        data.keys().hasAll(['userId', 'invoiceNumber', 'date', 'customerName', 'total', 'createdAt']) &&
        data.userId == userId &&
        data.invoiceNumber is string && data.invoiceNumber.size() <= 50 &&
        data.date is string && data.date.size() <= 50 &&
        data.customerName is string && data.customerName.size() <= 100 &&
        (data.subtotal is number || data.get('subtotal', 0) is number) &&
        (data.vat is number || data.get('vat', 0) is number) &&
        (data.total is number || data.total is string) &&
        data.createdAt == request.time;
    }

    // Invoices and Expenses Collections
    match /expenses/{expenseId} {
      allow read: if isSignedIn() && (resource == null || resource.data.get('userId', '') == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.get('userId', '') == request.auth.uid;
      allow update: if isSignedIn() && (resource == null || resource.data.get('userId', '') == request.auth.uid) && request.resource.data.get('userId', '') == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.get('userId', '') == request.auth.uid;
    }

    match /invoices/{invoiceId} {
      allow read: if isSignedIn() && (resource == null || resource.data.get('userId', '') == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.get('userId', '') == request.auth.uid;
      allow update: if isSignedIn() && (resource == null || resource.data.get('userId', '') == request.auth.uid) && request.resource.data.get('userId', '') == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.get('userId', '') == request.auth.uid;
    }
  }
}
