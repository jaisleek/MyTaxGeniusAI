# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Twilio Configuration for SMS Notifications
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="your_twilio_phone_number"

# Meta's Official WhatsApp Cloud API
META_WHATSAPP_TOKEN="your_meta_system_user_access_token"
META_VERIFY_TOKEN="taxbuddy_secure_token_123"

# Groq Configuration for Llama 3.3 70B
GROQ_API_KEY="your_groq_api_key_here"

# Google Maps Platform
GOOGLE_MAPS_PLATFORM_KEY="your_google_maps_api_key_here"

# Tawk.to Live Chat
VITE_TAWKTO_PROPERTY_ID="your_tawkto_property_id_here"
VITE_TAWKTO_WIDGET_ID="default"